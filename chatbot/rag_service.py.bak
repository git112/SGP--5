#!/usr/bin/env python3
"""
Production-Ready RAG Service for Placementor AI
Handles data ingestion, PII anonymization, vectorization, and querying with ChromaDB and an LLM via LangChain.

VERSION 3.0 - USES OLLAMA FOR BOTH EMBEDDINGS AND LLM
"""
# --- LangChain compatibility shim (try multiple import paths) ---
import importlib
import logging

_log = logging.getLogger(__name__)

def _try(name, attr=None):
    """Try to import module or attribute; return the attr or module or None."""
    try:
        m = importlib.import_module(name)
        return getattr(m, attr) if attr else m
    except Exception:
        return None

# Document, PromptTemplate
Document = _try("langchain.schema", "Document") or _try("langchain_core.documents", "Document") or _try("langchain_core.document", "Document")
PromptTemplate = _try("langchain.prompts.prompt", "PromptTemplate") or _try("langchain.prompts", "PromptTemplate") or _try("langchain_core.prompts", "PromptTemplate")

# Document loaders (PDF, DOCX)
PyPDFLoader = _try("langchain.document_loaders", "PyPDFLoader") or _try("langchain_community.document_loaders", "PyPDFLoader")
UnstructuredWordDocumentLoader = _try("langchain.document_loaders", "UnstructuredWordDocumentLoader") or _try("langchain_community.document_loaders", "UnstructuredWordDocumentLoader")

# Text splitter
RecursiveCharacterTextSplitter = _try("langchain_text_splitters", "RecursiveCharacterTextSplitter") or _try("langchain.text_splitter", "RecursiveCharacterTextSplitter")

# Vectorstore (Chroma)
Chroma = _try("langchain.vectorstores", "Chroma") or _try("langchain_community.vectorstores", "Chroma") or _try("langchain_core.vectorstores", "Chroma")

# Chains / chain classes
ConversationalRetrievalChain = (
    _try("langchain.chains.conversational_retrieval", "ConversationalRetrievalChain")
    or _try("langchain_community.chains.conversational_retrieval", "ConversationalRetrievalChain")
    or _try("langchain.chains", "ConversationalRetrievalChain")
)

LLMChain = _try("langchain", "LLMChain") or _try("langchain.chains", "LLMChain") or _try("langchain_core.chains", "LLMChain")

# Memory
ConversationBufferMemory = _try("langchain.memory", "ConversationBufferMemory") or _try("langchain_core.memory", "ConversationBufferMemory")

# Ollama bindings (embeddings + chat model)
OllamaEmbeddings = _try("langchain_ollama", "OllamaEmbeddings") or _try("langchain_ollama.embeddings", "OllamaEmbeddings")
ChatOllama = _try("langchain_ollama.chat_models", "ChatOllama") or _try("langchain_ollama", "ChatOllama")

# Quick check: collect missing pieces and raise informative error if critical ones are missing
_missing = []
for name, obj in [
    ("Document", Document),
    ("PromptTemplate", PromptTemplate),
    ("PyPDFLoader", PyPDFLoader),
    ("UnstructuredWordDocumentLoader", UnstructuredWordDocumentLoader),
    ("RecursiveCharacterTextSplitter", RecursiveCharacterTextSplitter),
    ("Chroma", Chroma),
    ("ConversationalRetrievalChain", ConversationalRetrievalChain),
    ("LLMChain", LLMChain),
    ("ConversationBufferMemory", ConversationBufferMemory),
    ("OllamaEmbeddings", OllamaEmbeddings),
    ("ChatOllama", ChatOllama),
]:
    if obj is None:
        _missing.append(name)

if _missing:
    _log.warning("LangChain compatibility shim could not find these symbols: %s", _missing)
    # If ConversationalRetrievalChain is missing, it's not fatal yet — we can fallback later.
    # But inform the user at import-time for clarity.

import os
import re
import logging
from typing import List, Dict, Any, Generator
from pathlib import Path
import pandas as pd

# LangChain / ecosystem imports (modern 1.x-compatible)
# document loaders
from langchain.document_loaders import PyPDFLoader, UnstructuredWordDocumentLoader

# text splitter (installed via langchain-text-splitters package)
from langchain_text_splitters import RecursiveCharacterTextSplitter

# vectorstore (Chroma adapter)
from langchain.vectorstores import Chroma

# canonical objects (1.x): Document and PromptTemplate moved to these modules
from langchain.schema import Document
from langchain.prompts.prompt import PromptTemplate

# Chains & chains utilities (modern path)
from langchain.chains import ConversationalRetrievalChain
from langchain import LLMChain

# Memory
from langchain.memory import ConversationBufferMemory

# Ollama embeddings/LLM (keep your existing ollama bindings)
from langchain_ollama import OllamaEmbeddings
from langchain_ollama import ChatOllama  # if your installed package exposes ChatOllama here

# Some community connectors may still exist under langchain_community but we prefer direct langchain imports above
# from langchain_community import ...   # only use if you need specific community modules later

from dotenv import load_dotenv

# Load environment variables
load_dotenv()

# Configure logging
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
logger = logging.getLogger(__name__)


class PlacementorRAGService:
    """
    A robust RAG service with conversational memory, PII redaction, 
    and intelligent data merging for analytical queries.
    """

    def __init__(self, data_folder: str = "./data", vector_db_path: str = "./vector_db"):
        self.data_folder = data_folder
        self.vector_db_path = vector_db_path
        self.vector_store = None
        self.qa_chain = None
        self.memory = None

        # PII patterns for anonymization
        self.pii_patterns = {
            'student_name': re.compile(r'\b[A-Z][a-z]+ [A-Z][a-z]+(?:\s+[A-Z][a-z]+)?\b'),
            'student_id': re.compile(r'\b(?:21BCP|22BCP|23BCP|24BCP|25BCP)[A-Z0-9]+\b|\b\d{7,}\b'),
            'email': re.compile(r'\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b'),
            'phone': re.compile(r'\b(?:\+91|91)?[6-9]\d{9}\b'),
            'roll_number': re.compile(r'\b\d{2}[A-Z]{2,4}\d{3,4}\b')
        }
        self._initialize_rag()

    def _initialize_models(self):
        """Initialize Nomic embeddings and the Llama 3 LLM (via Ollama)."""
        try:
            # --- EMBEDDING MODEL (NOMIC) ---
            self.embeddings = OllamaEmbeddings(model="nomic-embed-text")
            logger.info("OllamaEmbeddings (nomic-embed-text) initialized.")

            # --- LLM MODEL (OLLAMA) ---
            self.llm = ChatOllama(model="llama3", temperature=0.2)
            logger.info("ChatOllama initialized: llama3")

        except Exception as e:
            logger.error(f"Error initializing models: {e}", exc_info=True)
            logger.error("Please ensure Ollama is running and you have pulled the models: 'ollama pull nomic-embed-text' and 'ollama pull llama3'")
            raise
    
    def _initialize_rag(self):
        """Initialize the RAG system by loading or creating the vector database."""
        try:
            logger.info("Initializing Placementor RAG system...")
            
            # 1. Initialize AI Models
            self._initialize_models()

            # 2. Load or Create the Vector Database
            if os.path.exists(self.vector_db_path):
                logger.info("Loading existing vector database...")
                self.vector_store = Chroma(
                    persist_directory=self.vector_db_path,
                    embedding_function=self.embeddings
                )
            else:
                logger.info("Creating new vector database from merged data...")
                documents = self._load_and_process_documents() 
                
                if not documents:
                    logger.warning("No documents loaded, creating fallback document")
                    documents = [Document(
                        page_content="This is a placement assistance chatbot. No placement data is currently available.",
                        metadata={"source": "fallback", "type": "system"}
                    )]
                
                self.vector_store = Chroma.from_documents(
                    documents=documents,
                    embedding=self.embeddings,
                    persist_directory=self.vector_db_path
                )
                logger.info(f"Created vector database with {len(documents)} documents.")
            
            # 3. Setup the Conversational Chain
            self._setup_conversational_chain()
            
            logger.info("RAG system initialized successfully!")
            
        except Exception as e:
            logger.error(f"Error initializing RAG system: {e}", exc_info=True)
            raise

    def _load_and_process_documents(self) -> List[Document]:
        """
        Loads all files, merges Excel sheets into a master DataFrame,
        and creates one rich document per row/chunk.
        """
        logger.info("Starting data loading and merging process...")
        data_path = Path(self.data_folder)
        all_docs = []

        if not data_path.exists():
            logger.warning(f"Data folder '{self.data_folder}' does not exist.")
            return all_docs

        # 1. Process Excel Files (Master Data Merge)
        excel_files = list(data_path.glob("**/*.xlsx"))
        logger.info(f"Found {len(excel_files)} Excel files to process.")
        
        all_dfs = []
        for file_path in excel_files:
            try:
                year_match = re.search(r'\b(20\d{2})\b', file_path.name)
                if not year_match:
                    logger.warning(f"Skipping file without a year in its name: {file_path.name}")
                    continue
                
                year = int(year_match.group(1))
                
                xls = pd.ExcelFile(str(file_path))
                sheet_name = 'Sheet1' if 'Sheet1' in xls.sheet_names else xls.sheet_names[0]

                df = pd.read_excel(file_path, sheet_name=sheet_name)
                df['Year'] = year
                all_dfs.append(df)
            except Exception as e:
                logger.error(f"Could not process Excel file {file_path.name}: {e}")

        if all_dfs:
            master_df = pd.concat(all_dfs, ignore_index=True)
            logger.info(f"Created a master DataFrame with {len(master_df)} total rows.")

            master_df.columns = master_df.columns.str.lower().str.strip()
            column_map = {
                'student name': 'name',
                'student_name': 'name',
                'branch': 'branch',
                'b.tech cgpa (upto 6th sem)': 'cgpa',
                'cgpa': 'cgpa',
                'company name': 'company',
                'company': 'company',
                'roles offered': 'role',
                'role': 'role',
                'package': 'package_lpa',
                'package (lpa)': 'package_lpa',
                'package_lpa': 'package_lpa',
                'locations': 'location'
            }
            master_df.rename(columns=column_map, inplace=True)
            
            for index, row in master_df.iterrows():
                text_chunk = self._row_to_text(row)
                
                if text_chunk: 
                    anonymized_chunk = self._anonymize_pii(text_chunk)
                    all_docs.append(Document(
                        page_content=anonymized_chunk,
                        metadata={"source": f"ExcelData_Year_{row.get('Year', 'UNK')}", "row": index, "type": "placement_record"}
                    ))
            logger.info(f"Total documents created from Excel master sheet: {len(all_docs)}")

        # 2. Process PDF Files (Job Descriptions)
        pdf_files = list(data_path.glob("**/*.pdf"))
        logger.info(f"Found {len(pdf_files)} PDF files")
        for file_path in pdf_files:
            try:
                all_docs.extend(self._process_text_file(PyPDFLoader, file_path, "pdf_jd"))
            except Exception as e:
                logger.error(f"Error processing PDF file {file_path.name}: {e}")

        # 3. Process DOCX Files (Job Descriptions)
        docx_files = list(data_path.glob("**/*.docx"))
        logger.info(f"Found {len(docx_files)} DOCX files")
        for file_path in docx_files:
            try:
                all_docs.extend(self._process_text_file(UnstructuredWordDocumentLoader, file_path, "docx_jd"))
            except Exception as e:
                logger.error(f"Error processing DOCX file {file_path.name}: {e}")
        
        logger.info(f"Total documents processed from all sources: {len(all_docs)}")
        return all_docs

    def _row_to_text(self, row: pd.Series) -> str:
        """
        Creates a rich, descriptive sentence from a row of the standardized master DataFrame.
        This provides much better context for the LLM.
        """
        year = row.get("Year", "an unknown year")
        company = row.get("company", "N/A")
        package = row.get("package_lpa", "N/A")
        name = row.get("name", "A student") 
        role = row.get("role", "an unspecified role")
        branch = row.get("branch", "an unspecified branch")
        cgpa = row.get("cgpa", "N/A")

        if company == "N/A" or package == "N/A":
            return ""
            
        return (
            f"Placement Record (Year: {year}): A student named {name} from the {branch} "
            f"branch with a CGPA of {cgpa} was placed at {company} as a {role} "
            f"with a package of {package} LPA."
        )

    def _get_company_from_filename(self, filename: str) -> str:
        """Extracts a likely company name from a JD filename."""
        name_no_ext = Path(filename).stem
        name_normalized = re.sub(r'[_-]', ' ', name_no_ext)
        company = name_normalized.split(' ')[0]
        return company.capitalize()

    def _process_text_file(self, loader_class, file_path: Path, doc_type: str) -> List[Document]:
        """Generic processor for PDF and DOCX files that links them to company names."""
        documents = []
        loader = loader_class(str(file_path))
        pages = loader.load()
        text_splitter = RecursiveCharacterTextSplitter(chunk_size=800, chunk_overlap=150)
        chunks = text_splitter.split_documents(pages)
        
        company_name = self._get_company_from_filename(file_path.name)
        
        for i, chunk in enumerate(chunks):
            content = (
                f"This document is a Job Description from the company '{company_name}'. "
                f"It outlines required skills and qualifications. "
                f"Content (chunk {i+1}): {chunk.page_content}"
            )
            
            anonymized_content = self._anonymize_pii(content)
            
            chunk.metadata["source"] = str(file_path)
            chunk.metadata["file_name"] = file_path.name
            chunk.metadata["type"] = doc_type
            chunk.metadata["company_context"] = company_name 
            
            doc = Document(page_content=anonymized_content, metadata=chunk.metadata)
            documents.append(doc)
        return documents

    def _anonymize_pii(self, text: str) -> str:
        """Anonymizes PII in a given text string."""
        if not isinstance(text, str):
            return ""
        anonymized_text = text
        for key, pattern in self.pii_patterns.items():
            anonymized_text = pattern.sub(f'[{key.upper()}]', anonymized_text)
        return anonymized_text
    
    def _setup_conversational_chain(self):
        """Builds the ConversationalRetrievalChain with an advanced analyst prompt."""
        if not self.llm or not self.vector_store:
            self.qa_chain = None
            logger.warning("Cannot setup QA chain because LLM or Vector Store is not available.")
            return

        self.memory = ConversationBufferMemory(
            memory_key="chat_history", return_messages=True, output_key='answer'
        )

        retriever = self.vector_store.as_retriever(
            search_type="mmr",
            search_kwargs={"k": 7, "fetch_k": 20}
        )
        
        template = (
            """
You are 'Placementor AI', an expert placement data analyst for a university.
Your goal is to answer questions by aggregating, summarizing, and analyzing the provided context. 
You must be polite, helpful, and **strictly anonymous**.

**Context:**
{context}

**Rules for Answering:**
1.  **Strict Anonymity:** NEVER reveal personal names. When asked 'who' got a package, use placeholders like "A student", "A student from the [BRANCH] branch", or "A student named [STUDENT_NAME]".
    * **Correct:** "The highest package in 2024 was 45 LPA at Google, secured by a student from the Computer Engineering branch."
    * **Incorrect:** "The highest package was 45 LPA by John Doe."

2.  **Analytical Answers:** Answer analytical questions by summarizing the data.
    * **For 'Highest Package' Questions:** Scan all context for the highest package (LPA) for the given year(s). List the company and package.
    * **For 'Skills' Questions:** When asked for skills for a company (e.g., "skills for Google"), find the context from Job Descriptions (JDs) for that company and list the skills mentioned.
    * **For 'Comparison' Questions:** To find the 'best' or 'top' companies, list the companies with the highest packages from the context.

3.  **No Data Fallback:** If the answer is not in the context, say: "I'm sorry, I cannot find that specific information in the provided placement data."
4.  **Greetings:** For simple greetings (hi, hello), be friendly: "Hello! How can I help you with your placement questions today?"
5.  **Conciseness:** Be concise and to the point, but polite.

**Chat History:**
{chat_history}

**User's Question:**
{question}

**Your Answer:**
"""
        ).strip()
        
        self.qa_chain = ConversationalRetrievalChain.from_llm(
            llm=self.llm,
            retriever=retriever,
            memory=self.memory,
            return_source_documents=True,
            combine_docs_chain_kwargs={"prompt": PromptTemplate.from_template(template)},
            verbose=False # Set to True for debugging
        )
        logger.info("Memory-enabled RAG chain (Analytics v3 - Ollama) initialized successfully!")
    
    def process_query(self, query: str) -> Dict[str, Any]:
        """Processes a user query using the memory-enabled chain."""
        if not self.qa_chain:
            return {
                "answer": "I'm sorry, the AI model is not configured. Please check your API key and data.",
                "sources": []
            }
        
        try:
            lowered = (query or "").strip().lower()
            if lowered in {"hi", "hii", "hiii", "hello", "hey", "yo", "hola", "namaste"} or lowered.startswith("hi ") or lowered.startswith("hello ") or lowered.startswith("hey "):
                return {
                    "answer": "Hello! How can I help you with your placement questions today?",
                    "sources": []
                }
            
            result = self.qa_chain.invoke({"question": query})
            
            sources = []
            if "source_documents" in result:
                for doc in result["source_documents"]:
                    sources.append({
                        "content": doc.page_content,
                        "metadata": doc.metadata
                    })
            
            return {"answer": result["answer"], "sources": sources}

        except Exception as e:
            logger.error(f"Error processing query: {e}", exc_info=True)
            return {
                "answer": "I apologize, but I encountered an error. Please try again.",
                "sources": []
            }
    
    def process_query_stream(self_class, query: str) -> Generator[str, None, None]:
        """
        Processes a user query and yields streaming response.
        """
        try:
            lowered = (query or "").strip().lower()
            if lowered in {"hi", "hii", "hiii", "hello", "hey", "yo", "hola", "namaste"} or lowered.startswith("hi ") or lowered.startswith("hello ") or lowered.startswith("hey "):
                 yield "Hello! How can I help you with your placement questions today?"
                 return # Stop the generator

            result = self.process_query(query)
            answer = result.get("answer", "I apologize, but I encountered an error.")
            
            words = answer.split()
            current_chunk = ""
            for word in words:
                current_chunk += word + " "
                if len(current_chunk) > 30: 
                    yield current_chunk.strip()
                    current_chunk = ""
            
            if current_chunk.strip():
                yield current_chunk.strip()
                
        except Exception as e:
            logger.error(f"Error in streaming query: {e}")
            yield "I apologize, but I encountered an error. Please try again."

# Global instance for the application (so main.py can import it)
try:
    rag_service = PlacementorRAGService()
except Exception as e:
    logger.critical(f"Failed to initialize RAGService on startup: {e}", exc_info=True)
    rag_service = None # Set to None so main.py can check